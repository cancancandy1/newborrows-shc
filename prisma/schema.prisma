// Prisma Schema - SHC Equipment Borrowing System
// ระบบยืม-คืนอุปกรณ์กีฬา สถานกีฬาและสุขภาพ

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===========================
// Admin - ผู้ดูแลระบบ
// ===========================
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // เก็บเป็น bcrypt hash
  name      String
  role      AdminRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// บทบาทของ admin
enum AdminRole {
  ADMIN  // ผู้ดูแลระบบหลัก
  STAFF  // เจ้าหน้าที่
}

// ===========================
// EquipmentCategory - หมวดหมู่อุปกรณ์
// ===========================
model EquipmentCategory {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  equipments  Equipment[]

  @@map("equipment_categories")
}

// ===========================
// Equipment - อุปกรณ์
// ===========================
model Equipment {
  id             Int               @id @default(autoincrement())
  code           String            @unique  // รหัสอุปกรณ์
  name           String
  description    String?           @db.Text
  categoryId     Int
  stock          Int               @default(0)  // จำนวนทั้งหมด
  availableStock Int               @default(0)  // จำนวนที่ยืมได้
  imageUrl       String?
  status         EquipmentStatus   @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  category       EquipmentCategory @relation(fields: [categoryId], references: [id])
  borrowItems    BorrowItem[]

  @@index([categoryId])
  @@index([status])
  @@map("equipments")
}

// สถานะอุปกรณ์
enum EquipmentStatus {
  ACTIVE    // พร้อมให้ยืม
  INACTIVE  // ปิดการใช้งาน
  REPAIR    // อยู่ระหว่างซ่อม
}

// ===========================
// Borrow - รายการยืม
// ===========================
model Borrow {
  id          Int          @id @default(autoincrement())
  borrowCode  String       @unique  // รหัสการยืม เช่น SHC-BRW-2024-0001

  // ข้อมูลผู้ยืม
  studentId   String       // รหัสนักศึกษา/พนักงาน
  fullName    String
  department  String
  phone       String
  email       String

  // วันที่
  borrowDate  DateTime
  returnDate  DateTime
  returnedAt  DateTime?    // วันที่คืนจริง

  // สถานะ
  status      BorrowStatus @default(PENDING)

  // หมาย เหตุ
  note        String?      @db.Text

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items       BorrowItem[]
  history     BorrowStatusHistory[]

  @@index([status])
  @@index([borrowDate])
  @@index([studentId])
  @@map("borrows")
}

// สถานะการยืม
enum BorrowStatus {
  PENDING   // รอการอนุมัติ
  APPROVED  // อนุมัติแล้ว
  BORROWED  // กำลังยืม
  RETURNED  // คืนแล้ว
  REJECTED  // ถูกปฏิเสธ
}

// ===========================
// BorrowItem - รายการอุปกรณ์ที่ยืม
// ===========================
model BorrowItem {
  id          Int       @id @default(autoincrement())
  borrowId    Int
  equipmentId Int
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())

  borrow      Borrow    @relation(fields: [borrowId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  @@index([borrowId])
  @@index([equipmentId])
  @@map("borrow_items")
}

// ===========================
// BorrowStatusHistory - ประวัติการเปลี่ยนสถานะ
// ===========================
model BorrowStatusHistory {
  id         Int          @id @default(autoincrement())
  borrowId   Int
  status     BorrowStatus
  note       String?      @db.Text
  changedBy  String?      // ชื่อ admin ที่เปลี่ยนสถานะ
  createdAt  DateTime     @default(now())

  borrow     Borrow       @relation(fields: [borrowId], references: [id], onDelete: Cascade)

  @@index([borrowId])
  @@map("borrow_status_histories")
}
